BINANCE_BASE_URL=https://api.binance.com
BINANCE_RECV_WINDOW=5000
TRADING_SYMBOLS=XRPJPY
MAX_ACTIVE_SYMBOLS=3
QUOTE_ASSET=JPY
KLINE_INTERVAL=1h
KLINE_LIMIT=250
FAST_WINDOW=20
SLOW_WINDOW=50
MTF_ENTRY_INTERVAL=15m
