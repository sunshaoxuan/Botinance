GRID_SELL_STEP_PCT=0.003
GRID_BUYBACK_STEP_PCT=0.0025
GRID_SELL_FRACTION=0.25
GRID_MIN_CORE_POSITION_FRACTION=0.25
GRID_MAX_DAILY_TRADES=8
GRID_ALLOW_LOSS_RECOVERY_SELL=true
