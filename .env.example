BINANCE_BASE_URL=https://api.binance.com
BINANCE_RECV_WINDOW=5000
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT
MAX_ACTIVE_SYMBOLS=3
QUOTE_ASSET=USDT
KLINE_INTERVAL=1h
KLINE_LIMIT=250
FAST_WINDOW=20
SLOW_WINDOW=50
MTF_ENTRY_INTERVAL=15m
MTF_ENTRY_FAST_WINDOW=12
MTF_ENTRY_SLOW_WINDOW=26
MTF_TREND_INTERVAL=4h
MTF_TREND_FAST_WINDOW=20
MTF_TREND_SLOW_WINDOW=50
RISK_PER_TRADE=0.10
MIN_ORDER_NOTIONAL=25
TRADING_FEE_RATE=0.001
PAPER_QUOTE_BALANCE=1000
DRY_RUN=true
LLM_BASE_URL=http://ccnode.briconbric.com:49530/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_TIMEOUT_SECONDS=20
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_BASE_URL=http://ccnode.briconbric.com:22545
LLM_FALLBACK_MODEL=qwen3:14b
LLM_FALLBACK_TIMEOUT_SECONDS=30
LLM_FALLBACK_NUM_PREDICT=512
NEWS_REFRESH_SECONDS=120
DECISION_PRICE_MOVE_THRESHOLD_PCT=0.005
STOP_LOSS_PCT=0.01
TAKE_PROFIT_PCT=0.02
TRAILING_STOP_PCT=0.0075
MAX_HOLD_BARS=24
MIN_NET_EDGE_PCT=0.001
BUYBACK_COOLDOWN_BARS=5
BUYBACK_COOLDOWN_ALLOW_EMERGENCY_STOP=true
EXIT_STOP_LOSS_FRACTION=0.5
EXIT_EMERGENCY_STOP_FRACTION=1.0
EMERGENCY_STOP_CONFIRMATION_ENABLED=true
EXIT_TRAILING_STOP_FRACTION=0.5
EXIT_TAKE_PROFIT_FRACTION=0.5
EXIT_MAX_HOLD_FRACTION=0.25
STRATEGY_SELL_FRACTION=0.5
AI_CAN_CANCEL_BUYBACK=false
AI_EXTREME_RISK_CANCEL_BUYBACK=true
POSITION_ACTIVATION_ENABLED=true
POSITION_ACTIVATION_MODE=active_grid
GRID_SELL_STEP_PCT=0.003
GRID_BUYBACK_STEP_PCT=0.0025
GRID_SELL_FRACTION=0.25
GRID_MIN_CORE_POSITION_FRACTION=0.25
GRID_MAX_DAILY_TRADES=8
GRID_ALLOW_LOSS_RECOVERY_SELL=true
GRID_LOSS_RECOVERY_SELL_STEP_PCT=0.003
ORDER_EXECUTION_MODE=limit_lifecycle
ORDER_TIME_IN_FORCE=GTC
# Boti-managed stale check. GTC orders do not expire on Binance by themselves.
ORDER_STALE_SECONDS=180
ORDER_STALE_ACTION=observe
ORDER_REPRICE_ENABLED=true
ORDER_REPRICE_DEVIATION_PCT=0.003
ORDER_CANCEL_DEVIATION_PCT=0.003
ORDER_PASSIVE_OFFSET_PCT=0.0002
ORDER_URGENT_CROSS_PCT=0.001
ORDER_MAX_OPEN_PER_SYMBOL=1
LIVE_ORDER_EXECUTION_ENABLED=false

# Ultra-short paper test profile, keep DRY_RUN=true:
# KLINE_INTERVAL=1m
# KLINE_LIMIT=180
# FAST_WINDOW=3
# SLOW_WINDOW=9
# MTF_ENTRY_INTERVAL=1m
# MTF_ENTRY_FAST_WINDOW=2
# MTF_ENTRY_SLOW_WINDOW=5
# MTF_TREND_INTERVAL=5m
# MTF_TREND_FAST_WINDOW=6
# MTF_TREND_SLOW_WINDOW=18
# DECISION_PRICE_MOVE_THRESHOLD_PCT=0.0015
# STOP_LOSS_PCT=0.003
# TAKE_PROFIT_PCT=0.004
# TRAILING_STOP_PCT=0.0025
# MAX_HOLD_BARS=30
# GRID_SELL_STEP_PCT=0.0015
# GRID_BUYBACK_STEP_PCT=0.0012
# GRID_SELL_FRACTION=0.15
# GRID_MAX_DAILY_TRADES=30
# GRID_LOSS_RECOVERY_SELL_STEP_PCT=0.0015
# Boti-managed stale check; stale alone does not cancel GTC orders.
# ORDER_STALE_SECONDS=45
# ORDER_STALE_ACTION=observe
# ORDER_REPRICE_ENABLED=true
# ORDER_REPRICE_DEVIATION_PCT=0.0015
# ORDER_CANCEL_DEVIATION_PCT=0.0015
# ORDER_PASSIVE_OFFSET_PCT=0.0001
# ORDER_URGENT_CROSS_PCT=0.0005
SECRETS_ENABLED=true
SECRETS_FILE=.secrets.enc
SECRETS_CIPHER=aes-256-cbc
SECRETS_ITERATIONS=200000
SECRETS_KEYCHAIN_SERVICE=binance-ai-trader
SECRETS_KEYCHAIN_ACCOUNT=workspace-default
